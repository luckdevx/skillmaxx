{
  "name": "skillmaxx",
  "version": "0.5.2",
  "description": "Auto-detect and install the best AI agent skills for your project",
  "keywords": [
    "agent",
    "ai",
    "auto",
    "claude",
    "cli",
    "copilot",
    "cursor",
    "detect",
    "skills"
  ],
  "license": "CC-BY-NC-4.0",
  "author": "luckdevx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luckdevx/skillmaxx.git"
  },
  "bin": {
    "skillmaxx": "index.mjs"
  },
  "files": [
    "index.mjs",
    "dist/main.js",
    "skills-registry/index.json"
  ],
  "type": "module",
  "scripts": {
    "build": "esbuild main.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'tests/*.test.ts'",
    "validate:registry": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/validate-registry.mjs",
    "prepublishOnly": "pnpm run build && pnpm run validate:registry",
    "release": "node scripts/release.mjs",
    "sync:skills": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/sync-skills.mjs"
  },
  "devDependencies": {
    "@cliffy/command": "jsr:1.2.1",
    "@types/node": "22.15.3",
    "esbuild": "0.28.1",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
